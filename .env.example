# 日志
LOG_LEVEL=INFO
LOG_DIR=logs

# 初始资金
# INITIAL_CAPITAL=100000

# ============ 实盘交易 ============
# 交易后端: easytrader（同花顺）或 xtquant（miniQMT）
TRADER_BACKEND=easytrader

# easytrader - 同花顺
EASYTRADER_BROKER=ths
# 同花顺客户端路径（可选，不填则自动检测）
# THS_EXE_PATH=C:\同花顺\xiadan.exe

# miniQMT（备选，需券商开通权限）
# XTQUANT_ACCOUNT=your_account_id
# XTQUANT_PATH=D:\国泰海通证券\miniQMT\userdata_mini

# ============ 通知 ============
# Server酱 (微信推送)
# SERVERCHAN_KEY=your_serverchan_key

# 邮件通知
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your_email@qq.com
# SMTP_PASS=your_smtp_password
# NOTIFY_EMAIL=your_email@qq.com
